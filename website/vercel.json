{
  "rewrites": [
    { "source": "/live", "destination": "/live.html" },
    { "source": "/live-activity", "destination": "/live-activity.html" },
    { "source": "/launch", "destination": "/launch.html" },
    { "source": "/sign-in", "destination": "/sign-in.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/checkout", "destination": "/checkout.html" },
    { "source": "/cancel", "destination": "/cancel.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/start", "destination": "/start.html" },
    { "source": "/report", "destination": "/report.html" },
    { "source": "/welcome", "destination": "/welcome.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/live/:slug", "destination": "/client-live.html" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'none'" }
      ]
    },
    {
      "source": "/(.+\\.(png|jpg|jpeg|ico|svg|webp|gif|woff2|woff|ttf|css|js))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/checkout",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Content-Security-Policy", "value": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:" }
      ]
    },
    {
      "source": "/cancel",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Content-Security-Policy", "value": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:" }
      ]
    }
  ],
  "trailingSlash": false,
  "cleanUrls": true
}
